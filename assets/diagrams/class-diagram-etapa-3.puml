  enum CashMovementType {
    INCOME
    EXPENSE
  }

  enum BillingOrderStatus {
    PENDING
    PAID
    VOIDED
  }

  enum PaymentMethod {
    CASH
    CARD
    BANK_TRANSFER
    YAPE
    PLIN
  }

  enum ReceiptType {
    SALES_RECEIPT
    INVOICE
  }

  enum SunatStatus {
    PENDING
    ACCEPTED
    REJECTED
    VOIDED
  }

  enum IdentityDocumentType {
    NATIONAL_ID
    TAX_ID
    FOREIGNER_ID
  }

  CashRegister "1" --> "1" BillingBranchId : branch
  CashRegister "1" *-- "0..*" CashMovement
  CashRegister "1" --> "0..*" Payment
  BillingOrder "1" --> "1" BillingEncounterId : encounter
  BillingOrder "1" --> "1" BillingPatientId : patient
  BillingOrder "1" --> "0..1" BillingDispensingId : dispensing
  BillingOrder "1" *-- "0..*" Payment
  BillingOrder "1" --> "0..1" ElectronicInvoice
  Payment "1" --> "1" BillingAdministrativeStaffId : recordedBy
  ElectronicInvoice "1" *-- "1..*" InvoiceLineItem
  ElectronicInvoice "1" *-- "1" BillingCustomer
  ElectronicInvoice --> SunatGateway
  CashRegister --> CashRegisterStatus : status
  CashMovement --> CashMovementType : type
  BillingOrder --> BillingOrderStatus : status
  Payment --> PaymentMethod : method
  ElectronicInvoice --> ReceiptType : type
  ElectronicInvoice --> SunatStatus : sunatStatus
  BillingCustomer --> IdentityDocumentType : documentType
}

@enduml
